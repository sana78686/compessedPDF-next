# ─── Local development (copy to .env.local) ───────────────────────────────

# Laravel / GlobalCMS API (no trailing slash)
NEXT_PUBLIC_CMS_API_URL=https://app.apimstec.com

# Tenant hostname in CMS (Domains → domain), without protocol
NEXT_PUBLIC_SITE_DOMAIN=compresspdf.id

# Canonical public URL: scheme + host, NO trailing slash.
# Use the SAME host visitors use (pick ONE: www OR bare domain — match nginx/Plesk).
# Used for: metadataBase, Open Graph, sitemap.xml, robots.txt, CMS image URLs in SSR.
NEXT_PUBLIC_SITE_ORIGIN=https://compresspdf.id

# Same as Vite: try /{domain}/api/public/... first (default). Set false for X-Domain only.
# NEXT_PUBLIC_CMS_API_DOMAIN_PATH=true

# Client CMS cache (optional)
# NEXT_PUBLIC_CMS_CACHE_MS=60000
# NEXT_PUBLIC_CMS_SESSION_CACHE=true

# ─── Global CMS → frontend SEO push (server only; not NEXT_PUBLIC) ─────────
# Same value as FRONTEND_SEO_SYNC_SECRET in GlobalCMS .env. Enables “Push to live site”
# for robots / sitemap / home SEO. POST hits /cms-seo-sync.php (rewritten to /api/cms-seo-sync).
# CMS_SEO_SYNC_SECRET=
